# ── Supabase ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Dashboard → Project Settings → API). See SUPABASE_SETUP.md.
#
# .env.local is gitignored — never commit real keys.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (SERVER ONLY — bypasses RLS). Used by server actions and
# the seed script. Never prefix with NEXT_PUBLIC_ and never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
